FROM python:3.11-slim

# Install system dependencies for paramiko/cryptography and network tooling
RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        libffi-dev \
        libssl-dev \
        nmap \
        iputils-ping \
        net-tools \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy source and config before installing so hatchling can find packages
COPY pyproject.toml ./
COPY server/ ./server/
COPY cli/ ./cli/
COPY benchmarks/ ./benchmarks/
COPY deploy/alembic.ini ./alembic.ini

RUN pip install --no-cache-dir .

# Non-root user for security
RUN useradd -m -u 1000 scanner && chown -R scanner:scanner /app
USER scanner

EXPOSE 8000

CMD ["uvicorn", "server.main:app", "--host", "0.0.0.0", "--port", "8000"]
