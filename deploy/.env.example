# ============================================================
# Claude Scanner — Environment Configuration
# Copy this file to deploy/.env and fill in all values.
# NEVER commit the .env file to source control.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
POSTGRES_DB=claude_scanner
POSTGRES_USER=scanner
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql+asyncpg://scanner:CHANGE_ME_strong_password_here@postgres:5432/claude_scanner

# ------------------------------------------------------------
# Redis (Celery broker + result backend)
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------
# API / Auth
# ------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME_generate_a_long_random_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ------------------------------------------------------------
# 1Password Connect Server
# Store ALL credentials (SSH keys, WinRM passwords, etc.) in 1Password.
# The scanner fetches them at scan time — no credentials in this file.
# ------------------------------------------------------------
OP_CONNECT_HOST=http://your-1password-connect-server:8080
OP_CONNECT_TOKEN=CHANGE_ME_your_op_connect_token
# Optional: restrict lookups to a specific vault UUID
OP_VAULT_ID=

# ------------------------------------------------------------
# NVD (National Vulnerability Database) API
# Request a free key at: https://nvd.nist.gov/developers/request-an-api-key
# Store the actual key in 1Password and reference it here via env injection,
# or use your secrets manager to populate this at runtime.
# ------------------------------------------------------------
NVD_API_KEY=CHANGE_ME_your_nvd_api_key

# ------------------------------------------------------------
# Scanner Agent
# Shared secret used to authenticate the deployable Go agent.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ------------------------------------------------------------
AGENT_TOKEN=CHANGE_ME_generate_a_random_token
AGENT_PORT=9443

# ------------------------------------------------------------
# Network Scanner
# ------------------------------------------------------------
SCAN_TIMEOUT=30
SCAN_CONCURRENCY=100

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins for the dashboard
CORS_ORIGINS=http://localhost:3000
